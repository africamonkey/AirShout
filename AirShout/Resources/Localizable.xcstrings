    "onboarding.welcome" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to %@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "欢迎使用 %@"
          }
        }
      }
    },
    "onboarding.step.1.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AirPlay Shout"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AirPlay 设备喊话"
          }
        }
      }
    },
    "onboarding.step.1.desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Select AirPlay or Bluetooth device to stream audio wirelessly to TV, speakers, etc."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择 AirPlay 或蓝牙设备，将声音无线传输到电视、音响等设备"
          }
        }
      }
    },
    "onboarding.step.2.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Discover Nearby"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "发现附近设备"
          }
        }
      }
    },
    "onboarding.step.2.desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatically discover iOS devices running %@ and stream audio to them"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自动搜索同样运行了 %@ 的 iOS 设备，将声音传输到对方设备"
          }
        }
      }
    },
    "onboarding.step.3.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manual IP Connection"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "手动 IP 连接"
          }
        }
      }
    },
    "onboarding.step.3.desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enter the IP address of another iOS device, tap 'Start Receiving' on that device, then stream audio to it"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "输入对方 iOS 设备的 IP 地址，在对方设备上点击「开始接收」后，将声音传输到对方设备"
          }
        }
      }
    },
    "onboarding.step.4.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press to Speak"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按下说话"
          }
        }
      }
    },
    "onboarding.step.4.desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press button to start transmitting, press again to stop. Waveform shows real-time audio levels"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按下按钮开始传输，再次按下停止，波形图实时反馈音量"
          }
        }
      }
    },
    "onboarding.start" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Get Started"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开始使用"
          }
        }
      }
    }
  },
  "version" : "1.0"
}
